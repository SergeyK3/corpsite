BOT_TOKEN=change-me

# Backend connection
API_BASE_URL=http://127.0.0.1:8000
META_API_BASE_URL=http://127.0.0.1:8000

# Shared secrets with backend
BOT_BIND_TOKEN=change-me
INTERNAL_API_TOKEN=change-me

# Bot runtime
DATA_DIR=.data
ADMIN_TG_IDS=

# Events polling
EVENTS_POLL_INTERVAL_S=5
EVENTS_POLL_TYPES=
EVENTS_DELIVERY_CHANNEL=telegram
EVENTS_INTERNAL_API_USER_ID=1

# Optional explicit file paths
# BINDINGS_PATH=.data/bot_bindings.json
# EVENTS_STATE_PATH=.data/bot_events_state.json

# Optional HTTP trace for debugging
CORPSITE_HTTP_TRACE=0
