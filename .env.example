APP_ENV=dev

# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/corpsite
AUTH_JWT_SECRET=change-me
AUTH_JWT_EXPIRES_DAYS=10
BOT_BIND_TOKEN=change-me
INTERNAL_API_TOKEN=change-me
TG_BIND_CODE_TTL_MINUTES=30

# Directory / RBAC
DIRECTORY_RBAC_MODE=dept
DIRECTORY_PRIVILEGED_ROLE_IDS=
DIRECTORY_PRIVILEGED_USER_IDS=
ENABLE_DIRECTORY_DEBUG=1
ENABLE_LEGACY_X_USER_ID=1

# Backend behavior for generated regular tasks
TASK_STATUS_CODE_IN_PROGRESS=IN_PROGRESS
REGULAR_TASKS_TASK_KIND=regular
REGULAR_TASKS_SOURCE_KIND=regular_task

# Frontend
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Development-only helpers. Keep empty in production.
NEXT_PUBLIC_DEV_X_USER_ID=
DEV_X_USER_ID=
BACKEND_URL=http://127.0.0.1:8000
