APP_ENV=dev

# Backend
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/corpsite
# Required for pytest only — must point to a separate database (name ends with _test or -test).
# Never run pytest without TEST_DATABASE_URL; it must not target the same DB as DATABASE_URL.
TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/corpsite_test
AUTH_JWT_SECRET=dev-secret-change-me
# Fernet key or passphrase for encrypted recovery of applicant intake bearer tokens (required).
PERSONNEL_INTAKE_TOKEN_ENCRYPTION_KEY=dev-intake-token-encryption-key-change-me
PERSONNEL_INTAKE_LINK_TTL_DAYS=14
AUTH_JWT_EXPIRES_DAYS=10
BOT_BIND_TOKEN=change-me
INTERNAL_API_TOKEN=change-me
TG_BIND_CODE_TTL_MINUTES=30

# CORS (comma-separated; dev defaults applied when empty in non-prod)
# VPS split-port example: http://46.247.42.47:3000
# Same-origin nginx example: https://mmc.004.kz
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://46.247.42.47:3000

# Directory / RBAC
DIRECTORY_RBAC_MODE=dept
# Directory cross-dept scope only — does NOT open /admin/* sysadmin APIs (see ADR-042 guard split).
DIRECTORY_PRIVILEGED_ROLE_IDS=
# Privileged HR override (dev smoke). Example: user 34 = pall_head_34 / PALL_HEAD
# (Руководитель отдела кадров) for ADR-037 documents registry + personnel journal.
# Production: use role-based HR_ADMIN / HR_MANAGER instead of hardcoded user ids.
DIRECTORY_PRIVILEGED_USER_IDS=
SUPERVISOR_ROLE_IDS=
ENABLE_DIRECTORY_DEBUG=1
ENABLE_LEGACY_X_USER_ID=1

# ADR-042 — personnel access / enrollment (safe production defaults)
ADR042_ADMIN_GUARD_MODE=legacy
ADR042_LOGIN_MAX_FAILED_ATTEMPTS=5
ADR042_TOKEN_VERSION_ENFORCEMENT=false
ADR042_MUST_CHANGE_PASSWORD_ENFORCEMENT=false

# ADR-051 Phase 2.4 — cabinet access shadow diagnostics (legacy resolver remains source of truth)
CABINET_ACCESS_SHADOW_MODE=false

# Backend behavior for generated regular tasks
TASK_STATUS_CODE_IN_PROGRESS=IN_PROGRESS
REGULAR_TASKS_TASK_KIND=regular
REGULAR_TASKS_SOURCE_KIND=regular_task

# Frontend
NEXT_PUBLIC_APP_ENV=dev
# PPR personal card UI (dev: true; prod: omit or false until rollout)
NEXT_PUBLIC_PPR_CARD_ENABLED=true
# Dev: direct backend on split ports. Prod behind nginx: use /api or https://mmc.004.kz/api
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Development-only helpers. Keep empty in production.
NEXT_PUBLIC_DEV_X_USER_ID=
DEV_X_USER_ID=
# SSR / server-side fetch on VPS: direct to uvicorn (bypass nginx /api)
BACKEND_URL=http://127.0.0.1:8000

# Telegram bot (shared root .env)
BOT_TOKEN=
API_BASE_URL=http://127.0.0.1:8000
META_API_BASE_URL=http://127.0.0.1:8000
DATA_DIR=.data
ADMIN_TG_IDS=
EVENTS_POLL_INTERVAL_S=5
EVENTS_POLL_TYPES=
EVENTS_DELIVERY_CHANNEL=telegram
EVENTS_INTERNAL_API_USER_ID=1

# Cron service account user_id (system admin)
REGULAR_TASKS_CRON_USER_ID=1
# Initiator on generated tasks (default 1)
REGULAR_TASKS_SYSTEM_USER_ID=1
# Local TZ offset for due/period logic (default 5 = Asia/Almaty)
REGULAR_TASKS_TZ_OFFSET_HOURS=5
